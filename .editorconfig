# Enforces consistent formatting across the team

# top-most EditorConfig file
root = true

# All files
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

# YAML files (Spring application.yml, GitHub Actions)
[*.{yml,yaml}]
indent_size = 2

# Gradle and TOML files
[*.{gradle,toml}]
indent_size = 4

# Shell scripts
[*.sh]
end_of_line = lf
indent_size = 2

# Windows batch files (if any team members use Windows)
[*.bat]
end_of_line = crlf

# Markdown
[*.md]
trim_trailing_whitespace = false
