#Template for environment variables

# ==========================================
# VOQE LOCAL INFRASTRUCTURE ENVIRONMENT
# Copy this file to .env and fill in values
# ==========================================

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=local_dev_password
RABBITMQ_PORT=5672
RABBITMQ_UI_PORT=15672

# --- Database (PostgreSQL) ---
POSTGRES_DB=voqe_notifications
POSTGRES_USER=voqe_user
POSTGRES_PASSWORD=local_dev_password
POSTGRES_PORT=5432

# --- Observability (Jaeger / OTEL) ---
JAEGER_UI_PORT=16686
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# --- Third-Party Providers (Leave empty in local unless testing dispatch) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
SENDGRID_API_KEY=

# --- Application ---
LOG_LEVEL=DEBUG